{
  "name": "monkcli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "monkcli": "./scripts/monkcli"
  },
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "pnpm --filter @monkcli/cli dev",
    "build": "pnpm -r --if-present build",
    "test": "vitest",
    "install:launcher": "bash ./scripts/install-launcher.sh",
    "install:global": "bash ./scripts/install-launcher.sh",
    "docker:build": "docker build -t monkcli:local .",
    "docker:run": "docker run --rm -it monkcli:local"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
