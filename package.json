{
  "name": "monkcli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "monkcli": "./bin/monkcli.mjs"
  },
  "scripts": {
    "dev": "npm --prefix ./apps/cli run dev",
    "build": "node ./scripts/build-all.mjs",
    "test": "vitest",
    "install:launcher": "node ./scripts/install-launcher.mjs",
    "install:global": "node ./scripts/install-launcher.mjs",
    "uninstall:launcher": "node ./scripts/uninstall-launcher.mjs",
    "uninstall:global": "node ./scripts/uninstall-launcher.mjs",
    "docker:build": "docker build -t monkcli:local .",
    "docker:run": "docker run --rm -it monkcli:local"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
